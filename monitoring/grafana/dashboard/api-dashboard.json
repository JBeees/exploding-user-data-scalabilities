{
  "id": null,
  "uid": "plm-api-dashboard",
  "title": "Peak Load Management - API Dashboard",
  "tags": ["peak-load", "api", "performance"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (RPS)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total[1m]))",
        "legendFormat": "RPS"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 300},
              {"color": "red", "value": 500}
            ]
          },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m])) * 100",
        "legendFormat": "Error %"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "id": 3,
      "title": "Latency P95 (ms)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[1m])) by (le)) ",
        "legendFormat": "p95"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 2000}
            ]
          },
          "unit": "ms"
        }
      }
    },
    {
      "id": 4,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "expr": "db_connections_active",
        "legendFormat": "DB Connections"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 20},
              {"color": "red", "value": 24}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Latency Percentiles Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ms"}
      }
    },
    {
      "id": 6,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{
        "expr": "sum(rate(http_requests_total[1m])) by (path, method)",
        "legendFormat": "{{method}} {{path}}"
      }],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 7,
      "title": "Circuit Breaker State",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 12},
      "targets": [{
        "expr": "circuit_breaker_state",
        "legendFormat": "{{name}} state"
      }]
    },
    {
      "id": 8,
      "title": "Rate Limit Rejections",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 12},
      "targets": [{
        "expr": "sum(rate(rate_limit_rejected_total[1m]))",
        "legendFormat": "Rejected/s"
      }]
    },
    {
      "id": 9,
      "title": "Queue Depth (RabbitMQ)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 12},
      "targets": [{
        "expr": "queue_messages_pending",
        "legendFormat": "Pending Messages"
      }]
    },
    {
      "id": 10,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 18},
      "targets": [
        {
          "expr": "sum(rate(cache_hits_total[1m]))",
          "legendFormat": "Cache Hits/s"
        },
        {
          "expr": "sum(rate(cache_misses_total[1m]))",
          "legendFormat": "Cache Misses/s"
        }
      ]
    },
    {
      "id": 11,
      "title": "HTTP Status Code Distribution",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 18},
      "targets": [{
        "expr": "sum(rate(http_requests_total[1m])) by (status)",
        "legendFormat": "HTTP {{status}}"
      }]
    }
  ]
}
